{
  "name": "ph1water-music",
  "version": "1.0.0",
  "description": "play flac music",
  "main": "./out/main/index.js",
  "author": "ph1water",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:renderer": "tsc -p tsconfig.web.json --noEmit",
    "typecheck": "npm run typecheck:node && npm run typecheck:renderer",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@xhayper/discord-rpc": "^1.3.3",
    "chokidar": "^3.6.0",
    "fast-average-color": "^9.5.2",
    "framer-motion": "^11.0.0",
    "howler": "^2.2.4",
    "lucide-react": "^0.344.0",
    "music-metadata": "^11.12.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "youtube-dl-exec": "^3.1.5"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/chokidar": "^1.7.5",
    "@types/discord-rpc": "^4.0.10",
    "@types/howler": "^2.2.11",
    "@types/node": "^20.11.20",
    "@types/react": "^18.2.58",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.3.3",
    "vite": "^5.1.4"
  },
  "build": {
    "appId": "com.ph1water.musicplayer",
    "productName": "산성뮤직",
    "copyright": "Copyright © 2026 ph1water",
    "asarUnpack": [
      "node_modules/youtube-dl-exec/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": {
        "target": "default",
        "arch": [
          "universal"
        ]
      },
      "icon": "resources/icon.png",
      "category": "public.app-category.music",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "산성뮤직"
    }
  }
}
